# Server
NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/property-agent

# WhatsApp — Co-Founder's Meta Business Account
WHATSAPP_PHONE_NUMBER_ID=         # From Meta Developer App → WhatsApp → Getting Started
WHATSAPP_ACCESS_TOKEN=            # System User permanent token (never expires)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=    # Random string you choose (e.g. a UUID)
WHATSAPP_APP_SECRET=              # From Meta App → Settings → Basic → App Secret

# AI
GEMINI_API_KEY=                   # From Google AI Studio (aistudio.google.com)

# AWS S3 (flat photos)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=property-agent-photos

# Auth
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Expo Push Notifications
EXPO_ACCESS_TOKEN=                # From expo.dev → Account Settings → Access Tokens

# Daily digest schedule (9pm IST = 15:30 UTC)
DIGEST_CRON_UTC=30 15 * * *
