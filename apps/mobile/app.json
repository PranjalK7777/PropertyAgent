{
  "expo": {
    "name": "Property Agent",
    "slug": "property-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "property-agent",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f9f1e7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.propertyagent.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f9f1e7"
      },
      "package": "com.propertyagent.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#b85c38"
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d8018fea-5180-40ae-b3d1-5c78263c6ee2"
      }
    },
    "owner": "pranjalai"
  }
}
